<%- include("partials/header") %>

<main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 pt-3">
    <div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-3 border-bottom border-secondary">
        <h1 class="h2" style="color: var(--orange-main);">Editează <%= masina.marca %> <%= masina.model %></h1>
        <a href="/" class="btn btn-sm btn-outline-secondary text-white">Anulează</a>
    </div>

    <div class="card shadow-lg border-0" style="background-color: var(--black-matte); border: 1px solid var(--purple-accent) !important; border-radius: 15px;">
        <div class="card-body p-4">
            <form action="/edit/<%= masina.id %>" method="POST">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label text-secondary">Marcă</label>
                        <input type="text" name="marca" class="form-control form-control-dark" value="<%= masina.marca %>" required>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label text-secondary">Model</label>
                        <input type="text" name="model" class="form-control form-control-dark" value="<%= masina.model %>" required>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label text-secondary">Preț (€ / zi)</label>
                        <input type="number" name="pret" class="form-control form-control-dark" value="<%= masina.pret %>" required>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label text-secondary">Status</label>
                        <select name="status" class="form-select form-control-dark">
                            <option value="Disponibil" <%= masina.status === 'Disponibil' ? 'selected' : '' %>>Disponibil</option>
                            <option value="Închiriat" <%= masina.status === 'Închiriat' ? 'selected' : '' %>>Închiriat</option>
                            <option value="Mentenanță" <%= masina.status === 'Mentenanță' ? 'selected' : '' %>>Mentenanță</option>
                        </select>
                    </div>
                </div>

                <button type="submit" class="btn btn-warning w-100 fw-bold mt-3" style="background-color: var(--orange-main); border: none; color: white;">
                    Actualizează Datele
                </button>
            </form>
        </div>
    </div>
</main>

<%- include("partials/footer") %>