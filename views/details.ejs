<%- include("partials/header") %>

<main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 pt-4 text-white">
    <% if (typeof masina !== 'undefined' && masina) { %>
        
        <div class="d-flex justify-content-between align-items-center pb-3 mb-4 border-bottom border-secondary">
            <div>
                <h1 class="h2 fw-bold mb-0" style="color: var(--orange-main);"><%= masina.marca %> <%= masina.model %></h1>
                <span class="badge rounded-pill mt-2 <%= masina.status === 'Disponibil' ? 'bg-success' : (masina.status === 'Închiriat' ? 'bg-danger' : 'bg-warning text-dark') %>">
                    <%= masina.status %>
                </span>
            </div>
            <a href="/" class="btn btn-outline-light btn-sm"><i class="bi bi-arrow-left me-1"></i> Înapoi la Dashboard</a>
        </div>

        <div class="row g-4">
            <div class="col-lg-8">
                
                <div class="card bg-dark border-secondary p-4 mb-4">
                    <h5 class="text-info mb-3 small text-uppercase fw-bold"><i class="bi bi-info-circle me-2"></i>Specificații Vehicul</h5>
                    <div class="row text-center g-2">
                        <div class="col-6 col-md-3">
                            <div class="p-2 rounded bg-black bg-opacity-50 border border-secondary">
                                <small class="text-secondary d-block" style="font-size: 0.7rem;">KM ACTUALI</small>
                                <span class="fw-bold"><%= masina.km.toLocaleString() %></span>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="p-2 rounded bg-black bg-opacity-50 border border-secondary">
                                <small class="text-secondary d-block" style="font-size: 0.7rem;">MOTORIZARE</small>
                                <span class="fw-bold text-warning"><%= masina.motor %></span>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="p-2 rounded bg-black bg-opacity-50 border border-secondary">
                                <small class="text-secondary d-block" style="font-size: 0.7rem;">AN FABRICAȚIE</small>
                                <span class="fw-bold"><%= masina.an %></span>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="p-2 rounded bg-black bg-opacity-50 border border-secondary">
                                <small class="text-secondary d-block" style="font-size: 0.7rem;">CONSUM MEDIU</small>
                                <span class="fw-bold text-danger"><%= masina.consum %></span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm mb-4" style="background-color: #1a1a1a; border: 1px solid #444 !important;">
    <div class="card-body d-flex gap-3 justify-content-center py-4 flex-wrap">
        
        <% if (masina.status === 'Disponibil') { %>
            <form action="/update-status/<%= masina.id %>" method="POST">
                <input type="hidden" name="status" value="Închiriat">
                <button type="submit" class="btn btn-lg btn-warning fw-bold px-4">
                    <i class="bi bi-key-fill me-2"></i>PREDĂ CĂTRE CLIENT
                </button>
            </form>
        <% } %>

        <% if (masina.status === 'Închiriat') { %>
            <form action="/update-status/<%= masina.id %>" method="POST">
                <input type="hidden" name="status" value="Disponibil">
                <button type="submit" class="btn btn-lg btn-success fw-bold px-4">
                    <i class="bi bi-check-all me-2"></i>RECEPȚIE RETUR
                </button>
            </form>
        <% } %>

        <% if (masina.status === 'Mentenanță') { %>
            <form action="/update-status/<%= masina.id %>" method="POST">
                <input type="hidden" name="status" value="Disponibil">
                <button type="submit" class="btn btn-lg btn-info fw-bold px-4 text-white">
                    <i class="bi bi-play-circle-fill me-2"></i>REPORNEȘTE ACTIVITATEA
                </button>
            </form>
        <% } %>

        <% if (masina.status !== 'Mentenanță') { %>
            <form action="/update-status/<%= masina.id %>" method="POST">
                <input type="hidden" name="status" value="Mentenanță">
                <button type="submit" class="btn btn-lg btn-outline-danger fw-bold px-4">
                    <i class="bi bi-tools me-2"></i>TRIMITE ÎN SERVICE
                </button>
            </form>
        <% } %>

    </div>
</div>

                <% 
                    const kmRamasi = (masina.revizieLaKM || 0) - (masina.km || 0);
                    const esteUrgent = kmRamasi < 1000;
                %>
                <div class="card bg-dark border-secondary p-4">
                    <h5 class="text-white mb-3 small text-uppercase fw-bold"><i class="bi bi-wrench-adjustable me-2"></i>Plan Mentenanță</h5>
                    <div class="row align-items-center">
                        <div class="col-md-7">
                            <p class="text-info fw-bold mb-1"><%= masina.reparatie ? masina.reparatie.descriere : "Nicio lucrare programată" %></p>
                            <small class="text-muted">Cost estimat: <%= masina.reparatie ? masina.reparatie.cost : 0 %> €</small>
                        </div>
                        <div class="col-md-5 text-center mt-3 mt-md-0">
                            <div class="p-3 rounded border <%= esteUrgent ? 'border-danger bg-danger bg-opacity-10 text-danger' : 'border-success bg-success bg-opacity-10 text-success' %>">
                                <small class="text-white d-block mb-1">KM RĂMAȘI</small>
                                <h3 class="fw-bold mb-0"><%= kmRamasi.toLocaleString() %> KM</h3>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card bg-dark border-secondary p-4 mb-4" style="border-top: 4px solid #2ecc71 !important;">
                    <h6 class="text-secondary text-uppercase small fw-bold">Profit Luna Curentă</h6>
                    <% const venitBrut = (masina.pret || 0) * (masina.inchirieriLuna || 0); %>
                    <h2 class="text-success fw-bold mb-0">+ <%= venitBrut.toLocaleString() %> €</h2>
                    <hr class="border-secondary">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-secondary small">Zile închiriate:</span>
                        <span class="fw-bold"><%= masina.inchirieriLuna %></span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-secondary small">Cheltuieli:</span>
                        <span class="text-danger fw-bold">- <%= (masina.mentenantaLuna || 0) + (masina.combustibilLuna || 0) %> €</span>
                    </div>
                </div>

                <div class="card bg-dark border-secondary p-4 text-center">
                    <h6 class="text-secondary text-uppercase small fw-bold">Profit Istoric Total</h6>
                    <h2 class="text-white fw-bold mb-0"><%= (masina.profit || 0).toLocaleString() %> €</h2>
                </div>
            </div>
        </div>

    <% } else { %>
        <div class="alert alert-danger">Mașina nu a fost găsită în baza de date.</div>
    <% } %>
</main>

<%- include("partials/footer") %>