<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DRVEhub Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body>

<header class="navbar sticky-top flex-md-nowrap p-0 shadow">
    <a class="navbar-brand col-md-3 col-lg-2 me-0 px-3 d-flex align-items-center" href="/">
        <img src="/images/logoDRVEhub.svg" alt="DRVEhub Logo" style="height: 60px; width: auto;">
        <span class="ms-2" style="color: var(--orange-main); font-weight: bold;">ADMIN PANEL</span>
    </a>
    <form action="/" method="GET" class="w-100 px-3">
    <input name="search" 
           class="form-control form-control-dark w-100 rounded-0 border-0" 
           type="text" 
           placeholder="Caută în bază..." 
           aria-label="Search">
    </form>
    <div class="navbar-nav border-start border-secondary">
        <div class="nav-item text-nowrap">
            <a class="nav-link px-3" style="color: var(--orange-main) !important;" href="#">Sign out</a>
        </div>
    </div>
</header>

<div class="container-fluid">
    <div class="row">
        <nav id="sidebarMenu" class="col-md-3 col-lg-2 d-md-block sidebar collapse">
            <div class="position-sticky pt-3">
                <ul class="nav flex-column mt-3">
    <li class="nav-item mb-2">
        <a class="nav-link active py-3" href="/" style="color: var(--orange-main);">
            <i class="bi bi-speedometer2 me-2"></i> Dashboard
        </a>
    </li>

    <hr class="border-secondary mx-3">
    <p class="text-secondary small fw-bold px-3 text-uppercase mb-2">Status Flotă</p>

    <li class="nav-item mt-3">
    <a class="nav-link text-white py-2 fw-bold" href="/analytics" style="background: rgba(46, 204, 113, 0.1); border-radius: 8px;">
        <i class="bi bi-cash-stack me-2 text-success"></i> Raport Profit
    </a>
</li>

    <li class="nav-item">
    <a class="nav-link text-warning py-2" href="/service-board">
        <i class="bi bi-wrench-adjustable-circle me-2"></i> Jurnal Service
    </a>
</li>

    <li class="nav-item mb-2">
        <a class="nav-link text-white py-2" href="/status/Disponibil">
            <i class="bi bi-check-circle me-2 text-success"></i> Disponibile
        </a>
    </li>

    <li class="nav-item mb-2">
        <a class="nav-link text-white py-2" href="/status/Închiriat">
            <i class="bi bi-person-walking me-2 text-danger"></i> Închiriate
        </a>
    </li>

    <li class="nav-item mb-2">
        <a class="nav-link text-white py-2" href="/status/Mentenanță">
            <i class="bi bi-tools me-2 text-warning"></i> În Service
        </a>
    </li>
</ul>
            </div>
        </nav>

