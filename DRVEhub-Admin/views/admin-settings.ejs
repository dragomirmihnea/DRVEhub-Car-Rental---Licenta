<%- include("partials/header") %>
<main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
    <h2 class="mt-4 text-danger">Gestiune Administratori</h2>
    <table class="table table-dark table-striped mt-4">
        <thead>
            <tr><th>Username</th><th>Rol</th><th>Acțiuni</th></tr>
        </thead>
        <tbody>
            <% admins.forEach(admin => { %>
                <tr>
                    <td><%= admin.username %></td>
                    <td><%= admin.role %></td>
                    <td>
                        <% if (admin.role !== 'owner') { %>
                            <form action="/delete-admin" method="POST">
                                <input type="hidden" name="id" value="<%= admin.id %>">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Revocă Acces</button>
                            </form>
                        <% } %>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>
    <a href="/generate-code" class="btn btn-warning mt-3">Generare Cod Invitație Nou</a>
</main>
<%- include("partials/footer") %>